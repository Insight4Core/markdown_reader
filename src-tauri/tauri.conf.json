{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pyrus",
  "version": "0.2.1",
  "identifier": "com.gtechoogle.mdreader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Pyrus",
        "width": 1000,
        "height": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ1QjMwRDE1OTRENDk0REYKUldUZmxOU1VGUTJ6UlFicDZmWGlZUEltWFhRVGRQY2t6WTNHUWozNVBTZ1VSNWhqQldCdGhRbHUK",
      "endpoints": [
        "https://github.com/Insight4Core/markdown_reader/releases/latest/download/updater.json"
      ]
    }
  }
}
