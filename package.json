{
  "name": "markdown-reader",
  "version": "0.1.5",
  "description": "Markdown Reader Desktop Edition",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "version": "node -e \"const fs=require('fs'); const t=JSON.parse(fs.readFileSync('./src-tauri/tauri.conf.json')); t.version=process.env.npm_package_version; fs.writeFileSync('./src-tauri/tauri.conf.json', JSON.stringify(t, null, 2)+'\\n')\" && git add src-tauri/tauri.conf.json",
    "release:patch": "npm version patch && git push origin main && git push origin --tags",
    "release:minor": "npm version minor && git push origin main && git push origin --tags"
  },
  "license": "MIT",
  "dependencies": {
    "@md-reader/markdown-it-mermaid": "^0.6.0-beta.0",
    "@md-reader/theme": "^2.0.2",
    "@mdit/plugin-alert": "^0.23.2",
    "@smui/button": "^8.0.3",
    "@smui/chips": "^8.0.3",
    "@smui/form-field": "^8.0.3",
    "@smui/radio": "^8.0.3",
    "@smui/select": "^8.0.3",
    "@smui/switch": "^8.0.3",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-fs": "^2.5.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@traptitech/markdown-it-katex": "^3.6.0",
    "highlight.js": "^11.11.1",
    "lodash.debounce": "^4.0.8",
    "lodash.throttle": "^4.1.1",
    "markdown-it": "^14.1.1",
    "markdown-it-abbr": "^2.0.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-deflist": "^3.0.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-ins": "^4.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-multimd-table": "^4.2.3",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "markdown-it-table-of-contents": "^1.2.0",
    "markdown-it-task-lists": "^2.1.1"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tauri-apps/cli": "^2",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.5.2",
    "less": "^4.6.4",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
